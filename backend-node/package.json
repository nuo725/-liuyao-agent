{
  "name": "zhouyi-backend",
  "version": "1.0.0",
  "description": "Zhouyi Orbit Business Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test test/**/*.test.js",
    "test:unit": "node --test test/unit/**/*.test.js",
    "test:integration": "node --test test/integration/**/*.test.js",
    "test:contract": "node --test test/contract/**/*.test.js",
    "lint": "eslint src/ test/",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset",
    "db:studio": "npx prisma studio",
    "db:backup": "node scripts/db-backup.js",
    "db:restore": "node scripts/db-restore.js",
    "ops:security-check": "node scripts/security-check.js",
    "ops:adapter-check": "node scripts/adapter-check.js",
    "ops:perf-smoke": "node scripts/perf-smoke.js",
    "ops:perf-scenarios": "node scripts/perf-scenarios.js",
    "ops:alert-check": "node scripts/alert-check.js",
    "ops:acceptance-evidence": "node scripts/acceptance-evidence.js",
    "ops:acceptance-evidence:check": "node scripts/acceptance-evidence-validate.js",
    "ops:data-export": "node scripts/data-deletion.js --action=export",
    "ops:data-delete": "node scripts/data-deletion.js --action=delete --confirm",
    "worker:outbox": "node src/workers/outbox.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "prisma": "^6.9.0"
  }
}
