# Zhouyi Backend Environment Configuration
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_STORE=memory

# Database
DATABASE_URL="postgresql://zhouyi:zhouyi_dev_password@localhost:5432/zhouyi?schema=public"

# JWT
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"
JWT_ACCESS_TTL=7200
JWT_REFRESH_TTL=2592000

# SMS (optional - falls back to test code 123456)
SMS_PROVIDER=test
SMS_API_KEY=
SMS_API_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# Social Login (optional)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
QQ_APP_ID=
QQ_APP_SECRET=

# Object Storage (optional - falls back to local URLs)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# Push Notifications (optional)
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# Payment (optional)
PAYMENT_CALLBACK_SECRET="dev_callback_secret"

# Liuyao Agent (optional - separate service)
LIUYAO_AGENT_URL=
LIUYAO_AGENT_TOKEN=
